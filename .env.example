# ─── DATABASE ───────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bazares_db"

# ─── SERVER ─────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list if you need to allow multiple origins
# (e.g. production + staging): https://bazares.co.mz,https://staging.bazares.co.mz
FRONTEND_URL=http://localhost:5173

# ─── JWT ────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── BCRYPT ─────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── EMAIL (Gmail SMTP) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bazares09@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Bazares <bazares09@gmail.com>"

# ─── CLOUDINARY (Image Upload) ──────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── ADMIN ──────────────────────────────────────
ADMIN_EMAIL=ayronbanze0@gmail.com
ADMIN_PASSWORD=C@m@le@o
ADMIN_NAME=Ayron Banze

# ─── RATE LIMITING ──────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── PLATFORM FEE ───────────────────────────────
DEFAULT_FEE_RATE=2.0
FEE_LIMIT_MT=150
FEE_PAYMENT_NAME=José Jeque
FEE_PAYMENT_NUMBER=84 676 1897

# ─── WALLET ─────────────────────────────────────
# Email do utilizador ADMIN que recebe a comissão de plataforma na
# sua wallet interna. Se não definido, usa o ADMIN mais antigo (fallback).
PLATFORM_ADMIN_EMAIL=ayronbanze0@gmail.com
# Levantamento mínimo permitido (MT) — alinhado com o mínimo da ZumboPay
MIN_WITHDRAWAL_MT=1000

