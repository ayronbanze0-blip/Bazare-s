ZUMBOPAY_API_KEY=zk_live_94668b7c0d64fa967f9ae02e0f1e2b266a4e520f9976ac15
ZUMBOPAY_MERCHANT_ID=MCH_C32F4E71FC
ZUMBOPAY_BASE_URL=https://zumbopay.com/api/public/v1
# UUIDs das carteiras — obter via GET /wallets ou painel ZumboPay → Carteiras
