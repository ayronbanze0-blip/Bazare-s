# ─── Copia este ficheiro para .env e preenche com valores reais ────
# NUNCA faças commit do .env real — já está no .gitignore.

# ── Ambiente ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Base de dados (Railway → Postgres → Variables → DATABASE_URL) ─
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Autenticação (gera valores aleatórios longos, >=32 caracteres) ─
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=troca-por-um-valor-aleatorio-longo
JWT_REFRESH_SECRET=troca-por-outro-valor-aleatorio-longo
JWT_ACCESS_EXPIRES=15m
BCRYPT_ROUNDS=12

# ── Conta admin inicial (usada pelo prisma/seed.js) ────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=troca-por-uma-password-forte
PLATFORM_ADMIN_EMAIL=admin@example.com

# ── Cloudinary (upload de imagens e backups) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP (emails de verificação, recuperação de password, etc.) ────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── ZumboPay (pagamentos M-Pesa / eMola) ───────────────────────────
ZUMBOPAY_BASE_URL=
ZUMBOPAY_MERCHANT_ID=
ZUMBOPAY_API_KEY=
ZUMBOPAY_WEBHOOK_SECRET=
ZUMBOPAY_WALLET_MPESA=
ZUMBOPAY_WALLET_EMOLA=
ZUMBOPAY_TIMEOUT_MS=30000
STK_INFLIGHT_EXPIRY_MIN=5

# ── Regras de negócio ───────────────────────────────────────────────
DEFAULT_FEE_RATE=0.05
FEE_LIMIT_MT=0
FEE_PAYMENT_NAME=
FEE_PAYMENT_NUMBER=

# ── Rate limiting (opcional — já têm valores por omissão sensatos) ─
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
ORDER_RATE_LIMIT_MAX=60

# ── Backups (scripts/backup-db.js) ─────────────────────────────────
BACKUP_KEEP=14
