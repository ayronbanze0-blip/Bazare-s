generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────
model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  passwordHash      String
  role              Role      @default(BUYER)
  phone             String?
  location          String?
  bio               String?
  avatarUrl         String?
  coverUrl          String?

  // Auth
  verified          Boolean   @default(false)
  active            Boolean   @default(true)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?

  // Seller verification badge
  verifiedSeller    Boolean   @default(false)
  verificationRequestedAt DateTime?

  // Conta Premium — assinatura mensal (selo, destaque na pesquisa,
  // taxa reduzida, analytics avançado). isPremium é a flag rápida usada
  // em todas as leituras; premiumExpiresAt é a fonte de verdade — se
  // já passou, tratamos como não-premium mesmo que isPremium ainda
  // esteja true (ver premiumService.isActive / lazy downgrade).
  isPremium         Boolean   @default(false)
  premiumSince      DateTime?
  premiumExpiresAt  DateTime?

  // Conta de sistema do BazarBot (assistente de suporte por IA).
  // Só deve existir UMA linha com isBazarBot=true.
  isBazarBot        Boolean   @default(false)

  // Onboarding pós-registo (ecrã "o que pretende fazer / já tem loja /
  // onde ouviu falar"). onboardedAt fica null até a pessoa completar o
  // formulário (PUT /api/users/me/onboarding), que define a data.
  onboardedAt       DateTime?
  hasPhysicalStore  Boolean?
  referralSource    String?

  // Stats
  rating            Float     @default(0)
  ratingCount       Int       @default(0)
  cancelCount       Int       @default(0)
  thumbsUp          Int       @default(0)
  thumbsDown        Int       @default(0)

  // Revendedor system
  revendedorId      String?
  revendedor        User?     @relation("RevendedorSellers", fields: [revendedorId], references: [id])
  sellers           User[]    @relation("RevendedorSellers")
  inviteId          String?
  invite            RevendedorInvite? @relation(fields: [inviteId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  bazar             Bazar?
  orders            Order[]   @relation("BuyerOrders")
  sellerOrders      Order[]   @relation("SellerOrders")
  reviewsGiven      Review[]  @relation("ReviewsByUser")
  reviewsReceived   Review[]  @relation("ReviewsForSeller")
  notifications     Notification[]
  chatsAsA          Chat[]    @relation("ChatUserA")
  chatsAsB          Chat[]    @relation("ChatUserB")
  messagesSent      Message[]
  favorites         Favorite[]
  cartItems         CartItem[]
  tokens            RefreshToken[]
  verificationCodes VerificationCode[]
  reports           Report[]  @relation("ReportsByUser")
  reportsAgainst    Report[]  @relation("ReportsAgainstUser")
  invitesCreated    RevendedorInvite[] @relation("InviteCreator")
  transactions      Transaction[]      @relation("SellerTransactions")
  loginAttempts     LoginAttempt[]
  thumbVotesGiven   SellerThumbVote[]  @relation("ThumbVoter")
  thumbVotesReceived SellerThumbVote[] @relation("ThumbSeller")

  // Wallet system
  wallet              Wallet?
  depositRequests     DepositRequest[]
  withdrawalRequests  WithdrawalRequest[]
  commissionPayments  CommissionPayment[]   @relation("SellerCommissionPayments")
  reviewedDeposits    DepositRequest[]      @relation("DepositReviewedBy")
  reviewedWithdrawals WithdrawalRequest[]   @relation("WithdrawalReviewedBy")

  // Premium
  premiumSubscriptions PremiumSubscription[]
  quickReplies         QuickReply[]

  @@index([email])
  @@index([role])
  @@index([revendedorId])
  @@index([isPremium])
}

enum Role {
  ADMIN
  REVENDEDOR
  SELLER
  BUYER
}

// ─────────────────────────────────────────────
// AUTH TOKENS
// ─────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  // Quando e por qual token este foi substituído na rotação. Usados para
  // dar uma pequena janela de tolerância a pedidos de refresh concorrentes
  // (ex: duas abas, ou uma chamada de fundo e o carregamento de página a
  // disputar o mesmo cookie) — sem isto, o "perdedor" da corrida era
  // deslogado à força mesmo com uma sessão válida.
  revokedAt        DateTime?
  replacedByToken  String?
  userAgent String?
  ipAddress String?

  @@index([token])
  @@index([userId])
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   CodePurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, purpose])
}

enum CodePurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FACTOR
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ─────────────────────────────────────────────
// BAZARS
// ─────────────────────────────────────────────
model Bazar {
  id          String   @id @default(uuid())
  sellerId    String   @unique
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name        String
  slug        String   @unique
  description String   @db.Text
  category    String
  phone       String?
  location    String?
  bannerUrl   String?
  logoUrl     String?
  active      Boolean  @default(true)

  // Banner promocional personalizado (exclusivo Conta Premium)
  promoTitle    String?
  promoSubtitle String?
  promoColor    String?  // hex, ex: "#16A34A" — usado como cor de fundo do banner promocional

  // Financial
  feeRate       Float   @default(2.0)
  pendingFees   Float   @default(0)
  paidFees      Float   @default(0)
  totalSales    Float   @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
  orders      Order[]
  transactions Transaction[]

  @@index([category])
  @@index([active])
  @@index([active, category, createdAt])
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────
model Product {
  id             String   @id @default(uuid())
  bazarId        String
  bazar          Bazar    @relation(fields: [bazarId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name           String
  description    String   @db.Text
  price          Float
  category       String
  stock          Int      @default(0)
  condition      String   @default("Novo")
  size           String?
  color          String?
  location       String?
  deliveryMethod String   @default("Combinado")
  active         Boolean  @default(true)
  featured       Boolean  @default(false)

  // Moderação por IA — corre antes da publicação. APPROVED por
  // omissão para produtos criados antes desta funcionalidade existir.
  moderationStatus ModerationStatus @default(APPROVED)
  moderationReason String?

  // Stats
  rating         Float    @default(0)
  ratingCount    Int      @default(0)
  sales          Int      @default(0)
  views          Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  images         ProductImage[]
  orderItems     OrderItem[]
  reviews        Review[]
  favorites      Favorite[]
  cartItems      CartItem[]
  reports        Report[]

  @@index([bazarId])
  @@index([category])
  @@index([active])
  @@index([sellerId])
  // Compostos — cobrem os filtros+ordenação reais de list() em
  // productController (active sempre presente + 1 filtro + orderBy).
  @@index([active, category, createdAt])
  @@index([active, bazarId, createdAt])
  @@index([active, sellerId, createdAt])
  @@index([active, price])
  @@index([active, rating])
  @@index([active, sales])
  @@index([active, views])
  @@index([featured, active, sales])
}

enum ModerationStatus {
  APPROVED
  BLOCKED
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String? // Cloudinary public_id
  order     Int     @default(0)

  @@index([productId])
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────
model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  qty       Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// FAVORITES
// ─────────────────────────────────────────────
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// SELLER THUMB VOTES (👍/👎 na loja, um voto por comprador)
// ─────────────────────────────────────────────
model SellerThumbVote {
  id        String   @id @default(uuid())
  voterId   String
  voter     User     @relation("ThumbVoter", fields: [voterId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User     @relation("ThumbSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  vote      ThumbVote
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([voterId, sellerId])
  @@index([sellerId])
}

enum ThumbVote {
  UP
  DOWN
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────
model Order {
  id          String      @id @default(uuid())
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      User        @relation("SellerOrders", fields: [sellerId], references: [id])
  bazarId     String
  bazar       Bazar       @relation(fields: [bazarId], references: [id])
  status      OrderStatus @default(PENDENTE)

  // Buyer info
  buyerName   String
  buyerPhone  String
  address     String
  payment     String
  size        String?
  color       String?
  notes       String?     @db.Text

  // Financial
  subtotal    Float
  feeRate     Float       @default(2.0)
  feeAmount   Float       @default(0)
  total       Float

  rated       Boolean     @default(false)
  deliveredAt DateTime?
  cancelledAt DateTime?
  cancelReason String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
  review      Review?
  transaction Transaction?

  @@index([buyerId])
  @@index([sellerId])
  @@index([bazarId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  qty       Int
  imageUrl  String?

  @@index([orderId])
}

enum OrderStatus {
  PENDENTE
  ACEITE
  EM_PREPARACAO
  EM_ENTREGA
  ENTREGUE
  CANCELADA
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────
model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  sellerId   String
  seller     User     @relation("ReviewsForSeller", fields: [sellerId], references: [id])
  buyerId    String
  buyer      User     @relation("ReviewsByUser", fields: [buyerId], references: [id])
  rating     Int
  recommend  Boolean?
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([sellerId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// TRANSACTIONS
// ─────────────────────────────────────────────
model Transaction {
  id        String          @id @default(uuid())
  bazarId   String
  bazar     Bazar           @relation(fields: [bazarId], references: [id])
  orderId   String?         @unique
  order     Order?          @relation(fields: [orderId], references: [id])
  sellerId  String
  seller    User            @relation("SellerTransactions", fields: [sellerId], references: [id])
  type      TransactionType
  amount    Float
  fee       Float           @default(0)
  description String
  createdAt DateTime        @default(now())

  @@index([bazarId])
  @@index([sellerId])
}

enum TransactionType {
  VENDA
  PAGAMENTO
  AJUSTE
  REEMBOLSO
}

// ─────────────────────────────────────────────
// CHAT & MESSAGES
// ─────────────────────────────────────────────
model Chat {
  id        String    @id @default(uuid())
  userAId   String
  userA     User      @relation("ChatUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User      @relation("ChatUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text      String   @default("") @db.Text
  imageUrl  String?
  imagePublicId String?
  fromBot   Boolean  @default(false)
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
  @@index([read])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(INFO)
  title     String
  message   String           @db.Text
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ORDER
  CHAT
  REVIEW
  SYSTEM
}

// ─────────────────────────────────────────────
// REPORTS / DENUNCIAS
// ─────────────────────────────────────────────
model Report {
  id           String       @id @default(uuid())
  reporterId   String
  reporter     User         @relation("ReportsByUser", fields: [reporterId], references: [id])
  targetUserId String?
  targetUser   User?        @relation("ReportsAgainstUser", fields: [targetUserId], references: [id])
  targetProductId String?
  targetProduct   Product?  @relation(fields: [targetProductId], references: [id])
  type         ReportType
  reason       String
  description  String       @db.Text
  status       ReportStatus @default(PENDENTE)
  resolvedAt   DateTime?
  resolvedBy   String?
  resolution   String?      @db.Text
  createdAt    DateTime     @default(now())

  @@index([status])
  @@index([reporterId])
}

enum ReportType {
  PRODUCT
  USER
  BAZAR
}

enum ReportStatus {
  PENDENTE
  EM_ANALISE
  RESOLVIDA
  ARQUIVADA
}

// ─────────────────────────────────────────────
// REVENDEDOR INVITES
// ─────────────────────────────────────────────
model RevendedorInvite {
  id          String   @id @default(uuid())
  token       String   @unique
  note        String?
  createdById String
  createdBy   User     @relation("InviteCreator", fields: [createdById], references: [id])
  used        Boolean  @default(false)
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  usedByUsers User[]

  @@index([token])
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entity     String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// WALLET — saldo interno, extracto, transferências
// ─────────────────────────────────────────────
model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id           String              @id @default(uuid())
  walletId     String
  wallet       Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type         WalletTxType
  amount       Float               // sempre positivo; o sinal é dado pelo "type"
  balanceAfter Float               // saldo da wallet imediatamente após este movimento
  description  String
  status       WalletTxStatus      @default(CONCLUIDA)
  referenceType String?            // ex: "ORDER", "DEPOSIT", "WITHDRAWAL", "COMMISSION", "TRANSFER"
  referenceId   String?            // id da entidade relacionada
  createdAt    DateTime            @default(now())

  @@index([walletId])
  @@index([type])
  @@index([referenceType, referenceId])
}

enum WalletTxType {
  CREDITO_DEPOSITO
  DEBITO_LEVANTAMENTO
  TRANSFERENCIA_ENVIADA
  TRANSFERENCIA_RECEBIDA
  DEBITO_COMISSAO
  CREDITO_COMISSAO
  AJUSTE_ADMIN
}

enum WalletTxStatus {
  CONCLUIDA
  PENDENTE
  REJEITADA
  REVERTIDA
}

enum PaymentMethod {
  MPESA
  EMOLA
}

// ─────────────────────────────────────────────
// DEPOSITS — carregamento manual de saldo (comprovativo)
// ─────────────────────────────────────────────
model DepositRequest {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  method      PaymentMethod
  proofUrl    String?
  reference   String?        // comprovativo manual: texto livre; STK automático: referência da ZumboPay
  msisdn      String?        // só preenchido no fluxo automático (STK push)
  status      DepositStatus  @default(PENDENTE)
  reviewedById String?
  reviewedBy   User?         @relation("DepositReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt  DateTime?
  rejectReason String?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([reference])
}

enum DepositStatus {
  PENDENTE
  PROCESSANDO
  APROVADO
  REJEITADO
  FALHADA
}

// ─────────────────────────────────────────────
// WITHDRAWALS — levantamento manual (admin paga fora do sistema)
// ─────────────────────────────────────────────
model WithdrawalRequest {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Float
  method       PaymentMethod
  destination  String            // número de telefone M-Pesa/e-Mola
  status       WithdrawalStatus  @default(PENDENTE)
  reviewedById String?
  reviewedBy   User?             @relation("WithdrawalReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  rejectReason String?
  notes        String?
  createdAt    DateTime          @default(now())

  @@index([userId])
  @@index([status])
}

enum WithdrawalStatus {
  PENDENTE
  PAGO
  REJEITADO
}

// ─────────────────────────────────────────────
// COMMISSION PAYMENTS — pagamento da contribuição de plataforma
// (substitui o fluxo antigo de comprovativo manual)
// ─────────────────────────────────────────────
model CommissionPayment {
  id              String              @id @default(uuid())
  bazarId         String
  sellerId        String
  seller          User                @relation("SellerCommissionPayments", fields: [sellerId], references: [id])
  amount          Float
  method          CommissionMethod
  status          CommissionStatus    @default(PENDENTE)
  msisdn          String?             // telefone usado no STK push (método ZUMBOPAY)
  gatewayReference String?            // referência devolvida pela ZumboPay
  gatewayChannel   String?            // "mpesa" | "emola"
  failReason      String?
  createdAt       DateTime            @default(now())
  paidAt          DateTime?

  @@index([bazarId])
  @@index([sellerId])
  @@index([status])
  @@index([gatewayReference])
}

enum CommissionMethod {
  WALLET
  ZUMBOPAY
  MANUAL
}

// ─────────────────────────────────────────────
// CONTA PREMIUM
// ─────────────────────────────────────────────
// Um registo por ciclo de cobrança (mensal). O estado "actual" do
// utilizador vive em User.isPremium/premiumExpiresAt — esta tabela é
// o histórico/rasto de cada tentativa de pagamento via STK push.
model PremiumSubscription {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount           Float
  periodStart      DateTime?
  periodEnd        DateTime?
  status           PremiumSubStatus  @default(PROCESSANDO)
  msisdn           String?           // telefone usado no STK push
  gatewayReference String?           // referência devolvida pela ZumboPay
  gatewayChannel   String?           // "mpesa" | "emola"
  failReason       String?
  createdAt        DateTime          @default(now())
  paidAt           DateTime?

  @@index([userId])
  @@index([status])
  @@index([gatewayReference])
}

enum PremiumSubStatus {
  PROCESSANDO
  PAGA
  FALHADA
  CANCELADA
}

// Respostas rápidas personalizadas do vendedor no chat (exclusivo
// Conta Premium). Só texto pronto a inserir — nada de automação aqui.
model QuickReply {
  id        String   @id @default(uuid())
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  label     String   // curto, mostrado no botão (ex: "Prazo de entrega")
  text      String   @db.Text // texto completo inserido no campo de mensagem
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([sellerId])
}

enum CommissionStatus {
  PENDENTE
  PROCESSANDO
  PAGA
  FALHADA
}
